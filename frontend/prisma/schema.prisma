generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String   @unique
  password        String
  walletAddress   String?
  balance         Decimal  @default(0.0)

  // Relations
  transactions    Transaction[]

  escrowsAsBuyer  Escrow[] @relation("BuyerRelation")
  escrowsAsSeller Escrow[] @relation("SellerRelation")
  escrowsAsAdmin  Escrow[] @relation("AdminRelation")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Transaction {
  id        String           @id @default(cuid())

  userId    String
  user      User             @relation(fields: [userId], references: [id])

  amount    Decimal
  type      TransactionType
  stripeId  String?          // Stripe checkout session ID
  status    String           @default("SUCCESS")

  createdAt DateTime         @default(now())
}

model Escrow {
  id              String       @id @default(cuid())
  title           String
  currency        String       @default("USD")
  amount          Decimal
  description     String?
  deadline        DateTime?
  status          EscrowStatus @default(PENDING)
  onChainAddress  String?      @unique 

  buyerId         String
  buyer           User         @relation("BuyerRelation", fields: [buyerId], references: [id])

  sellerId        String
  seller          User         @relation("SellerRelation", fields: [sellerId], references: [id])

  creatorId       String
  creator         User         @relation("AdminRelation", fields: [creatorId], references: [id])

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum EscrowStatus {
  PENDING
  FUNDED
  LOCKED
  RELEASED
  DISPUTED
  CANCELLED
}